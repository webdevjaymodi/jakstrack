// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── USER ───────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(DEVELOPER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedBugs Bug[]         @relation("AssignedDeveloper")
  reportedBugs Bug[]         @relation("Reporter")
  assignedReqs Requirement[] @relation("ReqAssignee")
  createdReqs  Requirement[] @relation("ReqCreator")
  comments     Comment[]
  activities   Activity[]
  sessions     Session[]
}

enum Role {
  ADMIN
  QA
  DEVELOPER
}

// ─── PROJECT ────────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bugs         Bug[]
  requirements Requirement[]
}

// ─── BUG ────────────────────────────────────────────────────────────────────────

model Bug {
  id               String    @id @default(cuid())
  bugId            String    @unique
  module           String
  title            String
  description      String?
  stepsToReproduce String
  expectedResult   String
  actualResult     String
  severity         Severity  @default(MAJOR)
  priority         Priority  @default(HIGH)
  status           BugStatus @default(OPEN)
  screenshotUrl    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project      Project  @relation(fields: [projectId], references: [id])
  projectId    String
  assignedTo   User?    @relation("AssignedDeveloper", fields: [assignedToId], references: [id])
  assignedToId String?
  reportedBy   User?    @relation("Reporter", fields: [reportedById], references: [id])
  reportedById String?

  comments   Comment[]
  activities Activity[]

  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

enum Severity {
  MINOR
  MAJOR
  CRITICAL
  BLOCKER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BugStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  FIXED
  RETEST
  CLOSED
  REOPENED
}

// ─── REQUIREMENT ────────────────────────────────────────────────────────────────

model Requirement {
  id            String    @id @default(cuid())
  reqId         String    @unique
  title         String
  description   String
  priority      Priority  @default(MEDIUM)
  status        ReqStatus @default(PENDING)
  screenshotUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project     Project @relation(fields: [projectId], references: [id])
  projectId   String
  assignedTo  User?   @relation("ReqAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  createdBy   User?   @relation("ReqCreator", fields: [createdById], references: [id])
  createdById String?

  comments   Comment[]
  activities Activity[]

  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
}

enum ReqStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

// ─── COMMENT ────────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  bug           Bug?         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  bugId         String?
  requirement   Requirement? @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  requirementId String?

  @@index([bugId])
  @@index([requirementId])
}

// ─── ACTIVITY ───────────────────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  action    String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  bug           Bug?         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  bugId         String?
  requirement   Requirement? @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  requirementId String?

  @@index([bugId])
  @@index([requirementId])
  @@index([createdAt])
}

// ─── SESSION ────────────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([token])
  @@index([userId])
}
